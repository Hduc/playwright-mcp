{
    "name": "playwright-mcp",
    "version": "2.0.0",
    "description": "Playwright MCP Server — Node.js + Docker — Multi-browser automation for AI Agent",
    "main": "server.mjs",
    "type": "module",
    "scripts": {
        "start": "node server.mjs",
        "docker:build": "docker build -t playwright-mcp .",
        "docker:run": "docker run -d --name playwright-mcp -p 8000:8000 -e MCP_API_KEY=$MCP_API_KEY -v $(pwd)/sessions:/app/sessions playwright-mcp"
    },
    "dependencies": {
        "playwright": "^1.55.0"
    },
    "engines": {
        "node": ">=18"
    }
}
